# Auto-detect text files and normalise line endings
* text=auto

# Lock files — binary, no diff, ours on conflict
bun.lockb binary diff=false merge=ours

# Web assets — treat as binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary

# Exclude from repo language stats
*.json linguist-detectable=false
*.css linguist-detectable=false
